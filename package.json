{
  "name": "recipe-manager",
  "version": "1.0.0",
  "description": "Full-stack Recipe Manager with smart features",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "prisma:generate": "npm run prisma:generate --workspace=server",
    "prisma:push": "npm run prisma:push --workspace=server",
    "prisma:migrate": "npm run prisma:push --workspace=server",
    "prisma:studio": "npm run prisma:studio --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
